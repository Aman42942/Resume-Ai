{
  "name": "resume-ai-root",
  "version": "1.0.0",
  "description": "AI Resume Analyzer - run both frontend and backend together",
  "scripts": {
    "start": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"green,blue\" \"npm run backend\" \"npm run frontend\"",
    "frontend": "cd frontend && npm start",
    "backend": "cd backend && uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "install:all": "cd frontend && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
